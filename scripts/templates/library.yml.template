# library.yml — Library identity configuration
# This file controls everything identity-specific about your RAG library.
# Edit the TODO sections. All other code reads from this file.

library:
  name: TODO-library-slug          # lowercase, hyphens only (e.g. terence-mckenna)
  title: TODO Library Title        # e.g. "Terence McKenna Library"
  author: TODO Author Name         # e.g. "Terence McKenna"
  domain: philosophy               # philosophy | science | literature | history | ...
  subdomain: TODO.herakles.dev     # e.g. mckenna.herakles.dev
  description: "TODO: Describe your corpus (e.g. '150 lectures, 800K words...')"

ports:
  db: 5442       # assigned by fork-library.sh — change carefully
  api: 8140
  frontend: 3140

ragPersona:
  name: TODO Author Name
  shortDescription: >
    TODO: One sentence description of the author's background and significance.
    (e.g. "the American ethnobotanist, author, and speaker known for his
    explorations of psychedelics, consciousness, and archaic revival")
  voice: >
    TODO: Describe the author's speaking/writing voice.
    (e.g. "intellectual excitement, humor, and visionary speculation")
  keyThemes:
    - "TODO: Core theme 1 (be specific — this goes into the system prompt)"
    - "TODO: Core theme 2"
    - "TODO: Core theme 3"
    - "TODO: Core theme 4 (add as many as needed)"
  systemPromptTemplate: |
    You are {name}, {short_description}.

    You speak with {voice}.

    Key aspects of your philosophical/intellectual voice:
    {key_themes_bullet}

    CRITICAL RULES:
    1. ONLY use information from the provided transcript excerpts to answer questions
    2. If the excerpts don't contain relevant information, say so honestly — don't fabricate
    3. Weave the actual words and phrases from the excerpts into your response
    4. Cite which lecture/talk the ideas come from when possible
    5. Stay in character but never claim to have experiences you (as an AI) haven't had
    6. When quoting directly, use the actual words from the transcripts

topicRules:
  # Topic labeling rules for K-Means clustering.
  # Each rule: triggers (phrases/keywords to match), label (topic name), weight (1-3).
  # Higher weight = rule scores higher when its keywords appear in a cluster.
  # Tips:
  #   - Use 4-8 triggers per rule; multi-word phrases work well
  #   - weight: 3 = very specific niche topic
  #   - weight: 1.5 = broad category
  #   - weight: 1 = very broad (catch-all)
  #   - More rules = better topic labels (20-30 is good)

  # Example rules (customize for your author's corpus):
  - triggers: [TODO_keyword_1, TODO_keyword_2, TODO_phrase]
    label: "TODO Topic Name"
    weight: 3

  - triggers: [TODO_broader_1, TODO_broader_2]
    label: "TODO Broader Category"
    weight: 1.5

  # Add more rules here...

frontend:
  suggestions:
    - "TODO: search suggestion 1 (what would a reader want to find?)"
    - "TODO: search suggestion 2"
    - "TODO: search suggestion 3"
    - "TODO: search suggestion 4"
    - "TODO: search suggestion 5"
    - "TODO: search suggestion 6"
  heroTagline: "TODO: Explore the complete lectures, essays & dialogues"
  accentColor: "#d97706"   # amber — change to your preferred hex color
