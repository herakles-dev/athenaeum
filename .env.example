# Alan Watts Library — Environment Configuration
# Copy this file to .env and fill in your values.
# Never commit .env to git.

# ── Database (required) ────────────────────────────────────────────────────────
ALAN_WATTS_DB_PASSWORD=changeme

# ── LLM for chat — choose one provider ────────────────────────────────────────
# anthropic | openai | ollama | gemini | openrouter (default: openrouter)
LLM_PROVIDER=openrouter

# Model name (leave blank to use provider default)
# anthropic:   claude-sonnet-4-6 | claude-opus-4-6 | claude-haiku-4-5-20251001
# openai:      gpt-4o | gpt-4o-mini
# ollama:      llama3.2 | mistral | phi3
# gemini:      gemini-2.0-flash | gemini-1.5-pro
# openrouter:  leave blank for auto free-model fallback chain
LLM_MODEL=

# API key (not needed for ollama)
LLM_API_KEY=

# OpenRouter key (if using openrouter provider)
OPENROUTER_API_KEY=sk-or-...

# Base URL override (ollama or any OpenAI-compatible API)
# ollama local:  http://localhost:11434
# Docker ollama: http://host.docker.internal:11434
# Together AI:   https://api.together.xyz/v1
# Groq:          https://api.groq.com/openai/v1
LLM_BASE_URL=

# ── Pipeline keys (bulk embedding only) ────────────────────────────────────────
# Only needed when running embed.py (Gemini) or loader.py (Anthropic fallback)
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
