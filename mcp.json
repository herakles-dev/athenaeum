{
  "mcpServers": {
    "handbook-library": {
      "command": "python",
      "args": ["-m", "src.mcp_server"],
      "cwd": "/home/hercules/handbook-library",
      "env": {
        "HANDBOOK_LIBRARY_DB_PASSWORD": "${HANDBOOK_LIBRARY_DB_PASSWORD}",
        "LLM_PROVIDER": "${LLM_PROVIDER:-openrouter}",
        "LLM_MODEL": "${LLM_MODEL:-}",
        "LLM_API_KEY": "${LLM_API_KEY:-}",
        "OPENROUTER_API_KEY": "${OPENROUTER_API_KEY:-}",
        "ANTHROPIC_API_KEY": "${ANTHROPIC_API_KEY:-}"
      }
    }
  }
}
